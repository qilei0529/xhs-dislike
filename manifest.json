{
  "manifest_version": 3,
  "name": "XHS Dislike",
  "version": "0.1.0",
  "description": "Add dislike button to Xiaohongshu web feed cards",
  "permissions": [],
  "host_permissions": [
    "https://www.xiaohongshu.com/*",
    "https://edith.xiaohongshu.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.xiaohongshu.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["https://www.xiaohongshu.com/*"]
    }
  ]
}
